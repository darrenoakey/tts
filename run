#!/usr/bin/env python3
import argparse
import fcntl
import os
import subprocess
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent.resolve()
VENV = PROJECT_ROOT / ".venv"
VENV_PYTHON = VENV / "bin" / "python"
VENV_PIP = VENV / "bin" / "pip"
TEST_OUT = PROJECT_ROOT / "output" / "testing"
LOCK_FILE = PROJECT_ROOT / ".tts.lock"


# ##################################################################
# run in venv
# executes a command using the virtual environment python
def _run_venv(cmd: list[str], env: dict | None = None) -> int:
    run_env = os.environ.copy()
    run_env["VIRTUAL_ENV"] = str(VENV)
    run_env["PATH"] = f"{VENV / 'bin'}:{run_env.get('PATH', '')}"
    # suppress transformers warnings about model type and tokenizer regex
    run_env["TRANSFORMERS_VERBOSITY"] = "error"
    if env:
        run_env.update(env)
    return subprocess.call(cmd, cwd=PROJECT_ROOT, env=run_env)


# ##################################################################
# ensure venv
# create virtual environment if it does not exist
def _ensure_venv() -> None:
    if not VENV_PYTHON.exists():
        print("Creating virtual environment...")
        subprocess.call([sys.executable, "-m", "venv", str(VENV)])


# ##################################################################
# command install
# install dependencies into the virtual environment
def command_install(_: argparse.Namespace) -> int:
    _ensure_venv()
    print("Installing dependencies...")
    rc = _run_venv([str(VENV_PIP), "install", "-r", "requirements.txt"])
    if rc == 0:
        print("Dependencies installed successfully")
    return rc


# ##################################################################
# command tts
# run the tts tool to convert text to speech
# uses file lock to ensure only one instance runs at a time
def command_tts(args: argparse.Namespace) -> int:
    _ensure_venv()
    cmd = [str(VENV_PYTHON), "-m", "src.tts", "generate", str(args.input)]
    if args.output:
        cmd.extend(["-o", str(args.output)])
    if args.model:
        cmd.extend(["-m", args.model])
    if args.voice:
        cmd.extend(["-v", args.voice])
    if args.language:
        cmd.extend(["-l", args.language])
    if args.temperature:
        cmd.extend(["-t", str(args.temperature)])
    if args.speed:
        cmd.extend(["-s", str(args.speed)])
    if args.voice_description:
        cmd.extend(["-d", args.voice_description])
    if args.enhance:
        cmd.append("-e")

    with open(LOCK_FILE, "w") as lock:
        print("Waiting for TTS lock...", file=sys.stderr, flush=True)
        fcntl.flock(lock, fcntl.LOCK_EX)
        print("Lock acquired, starting TTS", file=sys.stderr, flush=True)
        return _run_venv(cmd, env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command design voice
# create a voice from a text description by generating a template audio
# then registering it as a clone voice for faster future synthesis
def command_design_voice(args: argparse.Namespace) -> int:
    _ensure_venv()

    # read the script that will be used for voice generation
    script_path = PROJECT_ROOT / "script.txt"
    if not script_path.exists():
        print(f"Error: Script file not found: {script_path}")
        return 1

    # read script content (skip comment lines starting with #)
    script_lines = []
    for line in script_path.read_text().splitlines():
        if not line.strip().startswith("#") and line.strip():
            script_lines.append(line.strip())
    script_text = " ".join(script_lines)

    # output paths
    voice_dir = PROJECT_ROOT / "local" / "designed" / args.name
    ref_audio = voice_dir / "reference.wav"

    # work directory for chunks (persistent for resume)
    work_dir = voice_dir / "chunks"

    code = f'''
import json
from pathlib import Path
from colorama import Fore, Style, init
init(autoreset=True)

from src.tts_engine import VoiceDesignEngine, VOICE_REGISTRY_PATH

voice_dir = Path("{voice_dir}")
voice_dir.mkdir(parents=True, exist_ok=True)
ref_audio = Path("{ref_audio}")
work_dir = Path("{work_dir}")

# generate audio from script using VoiceDesign model
print(f"{{Fore.BLUE}}🎙️  Generating voice template with VoiceDesign model...{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   Description: {{Style.DIM}}{args.description[:60]}...{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   Work dir: {{Style.DIM}}{{work_dir}}{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   This will take a while (1.7B model, ~5 min of audio){{Style.RESET_ALL}}")
print()

engine = VoiceDesignEngine(voice_description="""{args.description}""")
engine.synthesize(
    text="""{script_text}""",
    output_path=ref_audio,
    enhance={"True" if args.enhance else "False"},
    work_dir=work_dir,
)

print(f"\\n{{Fore.GREEN}}✓{{Style.RESET_ALL}} Generated reference audio: {{Fore.CYAN}}{{ref_audio}}{{Style.RESET_ALL}}")

# register as a clone voice
registry = {{}}
if VOICE_REGISTRY_PATH.exists():
    registry = json.loads(VOICE_REGISTRY_PATH.read_text())

# store the original description too for reference
registry["{args.name}"] = {{
    "type": "clone",
    "ref_audio": str(ref_audio),
    "ref_text": """{script_text}""",
    "description": """{args.description}""",
    "speed": {args.speed},
}}
VOICE_REGISTRY_PATH.write_text(json.dumps(registry, indent=2))

print(f"\\n{{Fore.GREEN}}✓{{Style.RESET_ALL}} Registered voice '{{Fore.CYAN}}{args.name}{{Style.RESET_ALL}}' as clone voice")
print(f"{{Fore.WHITE}}Use with:{{Style.RESET_ALL}} {{Fore.CYAN}}./run tts \\"hello world\\" -v {args.name}{{Style.RESET_ALL}}\\n")
'''

    max_retries = 10
    for attempt in range(max_retries):
        with open(LOCK_FILE, "w") as lock:
            print("Waiting for TTS lock...", file=sys.stderr, flush=True)
            fcntl.flock(lock, fcntl.LOCK_EX)
            print(f"Lock acquired, starting voice design (attempt {attempt + 1}/{max_retries})", file=sys.stderr, flush=True)
            rc = _run_venv([str(VENV_PYTHON), "-c", code], env={"PYTHONPATH": str(PROJECT_ROOT)})
            if rc == 0:
                return 0
            # check if it was a GPU crash (exit code is usually non-zero)
            print(f"\n⚠️  Process exited with code {rc}, checking if resumable...", file=sys.stderr, flush=True)
            # check if any chunks were created (progress was made)
            chunks_dir = voice_dir / "chunks"
            if chunks_dir.exists() and any(chunks_dir.iterdir()):
                print(f"✓ Found chunks in {chunks_dir}, will retry and resume", file=sys.stderr, flush=True)
                import time
                time.sleep(2)  # brief pause before retry
                continue
            else:
                print(f"✗ No progress made, not retrying", file=sys.stderr, flush=True)
                return rc
    print(f"✗ Max retries ({max_retries}) exceeded", file=sys.stderr, flush=True)
    return 1


# ##################################################################
# command export voice
# create a portable voice package (zip file) from a text description
# uses shorter script_30.txt for faster generation
def command_export_voice(args: argparse.Namespace) -> int:
    _ensure_venv()

    # read the short script for voice generation
    script_path = PROJECT_ROOT / "script_30.txt"
    if not script_path.exists():
        print(f"Error: Script file not found: {script_path}")
        return 1

    # read script content (skip comment lines starting with #)
    script_lines = []
    for line in script_path.read_text().splitlines():
        if not line.strip().startswith("#") and line.strip():
            script_lines.append(line.strip())
    script_text = " ".join(script_lines)

    # output paths
    output_dir = Path(args.output).resolve() if args.output else Path.cwd()
    output_zip = output_dir / f"{args.name}.voice.zip"
    work_dir = PROJECT_ROOT / "local" / "export" / args.name

    # map quality argument
    quality = args.quality

    code = f'''
import zipfile
import tempfile
from pathlib import Path
from colorama import Fore, Style, init
init(autoreset=True)

from src.tts_engine import VoiceDesignEngine

work_dir = Path("{work_dir}")
work_dir.mkdir(parents=True, exist_ok=True)

# generate audio from script using VoiceDesign model
print(f"{{Fore.BLUE}}🎙️  Generating voice template with VoiceDesign model...{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   Description: {{Style.DIM}}{args.description[:60]}...{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   Quality: {{Style.DIM}}{quality}{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}   Work dir: {{Style.DIM}}{{work_dir}}{{Style.RESET_ALL}}")
print()

ref_audio = work_dir / "voice.wav"
engine = VoiceDesignEngine(voice_description="""{args.description}""")
engine.synthesize(
    text="""{script_text}""",
    output_path=ref_audio,
    enhance=True,
    enhance_quality="{quality}",
    work_dir=work_dir / "chunks",
)

print(f"\\n{{Fore.GREEN}}✓{{Style.RESET_ALL}} Generated reference audio: {{Fore.CYAN}}{{ref_audio}}{{Style.RESET_ALL}}")

# create zip file
output_zip = Path("{output_zip}")
output_zip.parent.mkdir(parents=True, exist_ok=True)

with zipfile.ZipFile(output_zip, "w", zipfile.ZIP_DEFLATED) as zf:
    zf.write(ref_audio, "voice.wav")
    zf.writestr("voice.txt", """{script_text}""")

print(f"\\n{{Fore.GREEN}}✓{{Style.RESET_ALL}} Created voice package: {{Fore.CYAN}}{{output_zip}}{{Style.RESET_ALL}}")
print(f"{{Fore.WHITE}}Use with:{{Style.RESET_ALL}} {{Fore.CYAN}}./run tts \\"hello world\\" -v {{output_zip}}{{Style.RESET_ALL}}\\n")
'''

    max_retries = 10
    for attempt in range(max_retries):
        with open(LOCK_FILE, "w") as lock:
            print("Waiting for TTS lock...", file=sys.stderr, flush=True)
            fcntl.flock(lock, fcntl.LOCK_EX)
            print(f"Lock acquired, starting voice export (attempt {attempt + 1}/{max_retries})", file=sys.stderr, flush=True)
            rc = _run_venv([str(VENV_PYTHON), "-c", code], env={"PYTHONPATH": str(PROJECT_ROOT)})
            if rc == 0:
                return 0
            # check if it was a GPU crash (exit code is usually non-zero)
            print(f"\n⚠️  Process exited with code {rc}, checking if resumable...", file=sys.stderr, flush=True)
            # check if any chunks were created (progress was made)
            chunks_dir = work_dir / "chunks"
            if chunks_dir.exists() and any(chunks_dir.iterdir()):
                print(f"✓ Found chunks in {chunks_dir}, will retry and resume", file=sys.stderr, flush=True)
                import time
                time.sleep(2)  # brief pause before retry
                continue
            else:
                print(f"✗ No progress made, not retrying", file=sys.stderr, flush=True)
                return rc
    print(f"✗ Max retries ({max_retries}) exceeded", file=sys.stderr, flush=True)
    return 1


# ##################################################################
# command list voices
# list available voices
def command_list_voices(_: argparse.Namespace) -> int:
    _ensure_venv()
    cmd = [str(VENV_PYTHON), "-m", "src.tts", "list-voices"]
    return _run_venv(cmd, env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command scrape voice
# scrape voice samples from moviesoundclips.net and create a cloned voice
def command_scrape_voice(args: argparse.Namespace) -> int:
    _ensure_venv()
    cmd = [str(VENV_PYTHON), "-m", "src.voice_scraper", args.name]
    if args.quality == "hq":
        cmd.append("--hq")
    elif args.quality == "ultra":
        cmd.append("--ultra")
    return _run_venv(cmd, env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command clone voice
# create a cloned voice from an audio file
def command_clone_voice(args: argparse.Namespace) -> int:
    _ensure_venv()
    # resolve to absolute path
    audio_path = Path(args.audio).resolve()
    if not audio_path.exists():
        print(f"Error: Audio file not found: {audio_path}")
        return 1
    code = f"""
import json
from pathlib import Path
from colorama import Fore, Style, init
init(autoreset=True)

# transcribe the audio
print(f"{{Fore.BLUE}}📝 Transcribing audio with Whisper...{{Style.RESET_ALL}}")
import mlx_whisper
result = mlx_whisper.transcribe(
    "{audio_path}",
    path_or_hf_repo="mlx-community/whisper-large-v3-turbo",
)
ref_text = result["text"].strip()
print(f"{{Fore.GREEN}}✓{{Style.RESET_ALL}} Transcription: {{Style.DIM}}{{ref_text[:80]}}...{{Style.RESET_ALL}}" if len(ref_text) > 80 else f"{{Fore.GREEN}}✓{{Style.RESET_ALL}} Transcription: {{Style.DIM}}{{ref_text}}{{Style.RESET_ALL}}")

# register the voice
from src.tts_engine import VOICE_REGISTRY_PATH
registry = {{}}
if VOICE_REGISTRY_PATH.exists():
    registry = json.loads(VOICE_REGISTRY_PATH.read_text())

registry["{args.name}"] = {{
    "type": "clone",
    "ref_audio": "{audio_path}",
    "ref_text": ref_text,
    "speed": {args.speed},
}}
VOICE_REGISTRY_PATH.write_text(json.dumps(registry, indent=2))

print(f"\\n{{Fore.GREEN}}✓{{Style.RESET_ALL}} Registered voice '{{Fore.CYAN}}{args.name}{{Style.RESET_ALL}}'")
print(f"{{Fore.WHITE}}Use with:{{Style.RESET_ALL}} {{Fore.CYAN}}./run tts \\"hello world\\" -v {args.name}{{Style.RESET_ALL}}\\n")
"""
    return _run_venv([str(VENV_PYTHON), "-c", code], env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command list celebs
# list available celebrities from moviesoundclips.net
def command_list_celebs(_: argparse.Namespace) -> int:
    _ensure_venv()
    code = """
from colorama import Fore, Style, init
init(autoreset=True)
from src.voice_scraper import list_celebrities
celebs = list_celebrities()
print(f"\\n{Fore.BLUE}{Style.BRIGHT}Found {Fore.YELLOW}{len(celebs)}{Fore.BLUE} celebrities on moviesoundclips.net:{Style.RESET_ALL}\\n")
for person_id, name in celebs:
    print(f"  {Fore.WHITE}•{Style.RESET_ALL} {Fore.CYAN}{name}{Style.RESET_ALL}")
print()
"""
    return _run_venv([str(VENV_PYTHON), "-c", code], env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command multi
# run multi-speaker TTS from JSONL input
def command_multi(args: argparse.Namespace) -> int:
    _ensure_venv()
    cmd = [str(VENV_PYTHON), "-m", "src.tts", "multi", str(args.input)]
    if args.output:
        cmd.extend(["-o", str(args.output)])
    if args.language:
        cmd.extend(["-l", args.language])
    if args.temperature:
        cmd.extend(["-t", str(args.temperature)])
    if args.speed:
        cmd.extend(["-s", str(args.speed)])
    if args.enhance:
        cmd.append("-e")

    with open(LOCK_FILE, "w") as lock:
        print("Waiting for TTS lock...", file=sys.stderr, flush=True)
        fcntl.flock(lock, fcntl.LOCK_EX)
        print("Lock acquired, starting multi-speaker TTS", file=sys.stderr, flush=True)
        return _run_venv(cmd, env={"PYTHONPATH": str(PROJECT_ROOT)})


# ##################################################################
# command test
# run pytest for a specific test target and log output
def command_test(args: argparse.Namespace) -> int:
    _ensure_venv()
    TEST_OUT.mkdir(parents=True, exist_ok=True)
    target = args.target
    log = TEST_OUT / (target.replace("/", "_").replace("::", "_") + ".log")
    cmd = [str(VENV_PYTHON), "-m", "pytest", "-q", target, "--maxfail=1", "--disable-warnings"]
    with open(log, "w") as f:
        env = os.environ.copy()
        env["VIRTUAL_ENV"] = str(VENV)
        env["PATH"] = f"{VENV / 'bin'}:{env.get('PATH', '')}"
        env["PYTHONPATH"] = str(PROJECT_ROOT)
        rc = subprocess.call(cmd, stdout=f, stderr=subprocess.STDOUT, cwd=PROJECT_ROOT, env=env)
    print(f"Test output written to {log}")
    if rc != 0:
        print(log.read_text())
    return rc


# ##################################################################
# command lint
# run ruff linter with 120 char line length
def command_lint(_: argparse.Namespace) -> int:
    _ensure_venv()
    return _run_venv([str(VENV / "bin" / "ruff"), "check", "--line-length", "120", "src/"])


# ##################################################################
# command check
# run full test suite and quality gates via dazpycheck
def command_check(_: argparse.Namespace) -> int:
    return subprocess.call(["dazpycheck"], cwd=PROJECT_ROOT)


# ##################################################################
# main
# parse arguments and dispatch to the appropriate command handler
def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="run", description="TTS project runner")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_install = sub.add_parser("install", help="Install dependencies into venv")
    p_install.set_defaults(func=command_install)

    p_tts = sub.add_parser("tts", help="Convert text file to speech")
    p_tts.add_argument("input", type=Path, help="Input text file")
    p_tts.add_argument("-o", "--output", type=Path, help="Output audio file")
    p_tts.add_argument("-m", "--model", help="TTS model (default: qwen)")
    p_tts.add_argument("-v", "--voice", help="Voice name (built-in or custom)")
    p_tts.add_argument("-l", "--language", help="Language (default: English)")
    p_tts.add_argument("-t", "--temperature", type=float, help="Temperature (default: 0.9)")
    p_tts.add_argument("-s", "--speed", type=float, help="Speed multiplier 0.5-2.0 (default: 1.0)")
    p_tts.add_argument("-d", "--voice-description", help="Voice description for on-the-fly voice design")
    p_tts.add_argument("-e", "--enhance", action="store_true", help="Apply AI enhancement (ultra quality, slower)")
    p_tts.set_defaults(func=command_tts)

    p_design = sub.add_parser("design-voice", help="Create voice from description (generates template, saves as clone)")
    p_design.add_argument("name", help="Voice name (e.g., 'gary')")
    p_design.add_argument("description", help="Voice description (e.g., 'A British male newsreader...')")
    p_design.add_argument("-s", "--speed", type=float, default=1.0, help="Default speed for this voice")
    p_design.add_argument("-e", "--enhance", action="store_true", help="Apply AI enhancement to template audio")
    p_design.set_defaults(func=command_design_voice)

    p_export = sub.add_parser("export-voice", help="Create portable voice package (zip file) from description")
    p_export.add_argument("name", help="Voice package name (creates name.voice.zip)")
    p_export.add_argument("description", help="Voice description (e.g., 'A British male newsreader...')")
    p_export.add_argument("-o", "--output", type=Path, help="Output directory (default: current directory)")
    p_export.add_argument("-q", "--quality", choices=["default", "hq", "ultra"], default="hq",
                          help="Enhancement quality: default (fastest), hq (default), ultra (slowest)")
    p_export.set_defaults(func=command_export_voice)

    p_list = sub.add_parser("list-voices", help="List available voices")
    p_list.set_defaults(func=command_list_voices)

    p_scrape = sub.add_parser("scrape-voice", help="Scrape voice samples from moviesoundclips.net")
    p_scrape.add_argument("name", help="Person name to search for (e.g., 'Nathan Fillion')")
    p_scrape.add_argument("--hq", dest="quality", action="store_const", const="hq", default="ultra",
                          help="High quality enhancement (faster than ultra)")
    p_scrape.add_argument("--fast", dest="quality", action="store_const", const="default",
                          help="Fast enhancement (lowest quality)")
    p_scrape.set_defaults(func=command_scrape_voice)

    p_clone = sub.add_parser("clone-voice", help="Create a cloned voice from an audio file")
    p_clone.add_argument("name", help="Voice name (e.g., 'myvoice')")
    p_clone.add_argument("audio", help="Path to audio file (WAV recommended)")
    p_clone.add_argument("-s", "--speed", type=float, default=1.0, help="Default speed for this voice")
    p_clone.set_defaults(func=command_clone_voice)

    p_celebs = sub.add_parser("list-celebs", help="List available celebrities from moviesoundclips.net")
    p_celebs.set_defaults(func=command_list_celebs)

    p_multi = sub.add_parser("multi", help="Generate multi-speaker dialogue from JSONL")
    p_multi.add_argument("input", type=Path, help="Input JSONL file with dialogue")
    p_multi.add_argument("-o", "--output", type=Path, help="Output audio file")
    p_multi.add_argument("-l", "--language", help="Language (default: English)")
    p_multi.add_argument("-t", "--temperature", type=float, help="Temperature (default: 0.9)")
    p_multi.add_argument("-s", "--speed", type=float, help="Speed multiplier 0.5-2.0 (default: 1.0)")
    p_multi.add_argument("-e", "--enhance", action="store_true", help="Apply AI enhancement (ultra quality, slower)")
    p_multi.set_defaults(func=command_multi)

    p_test = sub.add_parser("test", help="Run a single test target")
    p_test.add_argument("target", help="e.g. src/tts_engine_test.py::test_get_engine_returns_qwen_for_default")
    p_test.set_defaults(func=command_test)

    p_lint = sub.add_parser("lint", help="Run linter")
    p_lint.set_defaults(func=command_lint)

    p_check = sub.add_parser("check", help="Run full suite and gates (dazpycheck)")
    p_check.set_defaults(func=command_check)

    args = parser.parse_args(argv)
    return args.func(args)


# ##################################################################
# entry point
# standard python dispatch to main

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
